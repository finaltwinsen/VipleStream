*pro.user


**/.vs/
.vscode/
build/
# Third-party SDK layouts under libs/ keep their upstream "build/"
# folder for native headers — not a build output, track them.
!libs/windows/onnxruntime/build/
!libs/windows/onnxruntime/build/**
config.tests/*/.qmake.stash
config.tests/*/Makefile

# Generated by qmake QMAKE_SUBSTITUTES from app/version.txt at build time.
# Source of truth is app/version_string.h.in (tracked).
app/version_string.h

<?xml version="1.0" encoding="utf-8"?>
<!--
    VipleStream editorial host tile.
    Preserves grid_image / grid_overlay / grid_spinner / grid_text IDs
    so PcGridAdapter + GenericGridAdapter bind exactly like before.
    New decorative elements (ink2 frame, "§ HOST" meta label, paper-
    bold name styling) are non-ID children, purely for look.
-->
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:padding="8dp">

    <LinearLayout
        android:layout_width="165dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/vs_tile_bg"
        android:padding="12dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp">

            <TextView
                android:tag="vs_meta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:text="§ HOST"
                android:textSize="9sp"
                android:textColor="@color/vs_mute"
                android:fontFamily="@font/ibm_plex_mono"
                android:letterSpacing="0.14" />

            <!--
                VipleStream H.5 capability badge.  PcGridAdapter sets
                visibility based on ComputerDetails.isVipleStreamPeer.
                Vanilla Sunshine / GFE peers show no badge.  Drawn as a
                compact lime-bordered "V" on ink3 to match the Qt client's
                badge.
            -->
            <TextView
                android:id="@+id/grid_viple_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:visibility="gone"
                android:text="V"
                android:textSize="9sp"
                android:textStyle="bold"
                android:textColor="@color/vs_lime"
                android:fontFamily="@font/ibm_plex_mono"
                android:background="@drawable/vs_viple_badge_bg"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:paddingTop="1dp"
                android:paddingBottom="1dp"
                android:letterSpacing="0.14" />
        </RelativeLayout>

        <RelativeLayout
            android:id="@+id/grid_image_layout"
            android:layout_width="match_parent"
            android:layout_height="125dp"
            android:background="@color/vs_ink">

            <ImageView
                android:id="@+id/grid_image"
                android:layout_centerInParent="true"
                android:layout_width="100dp"
                android:layout_height="100dp" />

            <!--
                grid_overlay 要對齊「螢幕本體視覺中心」，不是整個
                ic_computer drawable 的幾何中心。ic_computer 的
                viewport 是 24x24，螢幕區塊佔 y=2..16（視覺中心 y≈9），
                腳座佔 y=18..22。幾何中心 (12,12) 落在螢幕下緣與腳
                座之間的空隙 —— 如果 overlay centerInParent，警告
                三角形會黏在螢幕下緣而不是螢幕正中央。

                公式：grid_image 100dp，螢幕中心離 grid_image top
                = 100 * 9/24 ≈ 37.5dp。overlay 50dp，要讓其中心落
                在該點 → marginTop = 37.5 - 25 = 12.5dp ≈ 13dp。
                如果日後改 ic_computer 的 viewport 或 grid_image
                尺寸，這個偏移需要重算。
            -->
            <ImageView
                android:id="@+id/grid_overlay"
                android:layout_alignTop="@id/grid_image"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="13dp"
                android:layout_width="50dp"
                android:layout_height="50dp" />

            <!--
                Spinner 是「處理中」語意（state=UNKNOWN 時顯示，例
                如 polling 中），不必對齊螢幕；對齊整個框中央更像
                一般 loading indicator 的直覺位置，保持原行為。
            -->
            <ProgressBar
                android:id="@+id/grid_spinner"
                android:layout_centerInParent="true"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:indeterminate="true" />
        </RelativeLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="10dp"
            android:background="@color/vs_line" />

        <TextView
            android:id="@+id/grid_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="@color/vs_paper"
            android:textSize="15sp"
            android:textStyle="bold"
            android:fontFamily="@font/inter"
            android:gravity="left"
            android:maxLines="2"
            android:ellipsize="end" />
    </LinearLayout>
</RelativeLayout>

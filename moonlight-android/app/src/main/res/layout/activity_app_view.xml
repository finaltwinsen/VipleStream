<!--
    VipleStream editorial app library header.
    Keeps appFragmentContainer + appListText IDs so AppView.java
    bindings still work.  appListText now carries the PC name as
    an editorial paper-bold heading, with a new "§ 03 · LIBRARY"
    mono meta label directly above it.  The grid container is
    layout_below=@appListText (unchanged) so the list of games
    still flows underneath the header block.
-->
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".AppView" >

    <TextView
        android:id="@+id/appListMeta"
        android:tag="vs_meta"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:layout_alignParentTop="true"
        android:gravity="center"
        android:paddingTop="10dp"
        android:text="§ 03 · LIBRARY"
        android:textColor="@color/vs_lime"
        android:textSize="11sp"
        android:fontFamily="@font/ibm_plex_mono"
        android:letterSpacing="0.18" />

    <TextView
        android:id="@+id/appListText"
        android:tag="vs_display_large"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:layout_below="@+id/appListMeta"
        android:gravity="center"
        android:paddingTop="2dp"
        android:paddingBottom="8dp"
        android:preferKeepClear="true"
        android:textColor="@color/vs_paper"
        android:textSize="24sp"
        android:textStyle="bold"
        android:fontFamily="@font/space_grotesk"
        android:letterSpacing="-0.02" />

    <!--
        VipleStream H.4: Steam profile dropdown.  Visibility starts at GONE
        and is flipped to VISIBLE in AppView.java only when the host is a
        VipleStream peer that returned a non-empty profiles list from
        /steamprofiles.  Sits between the PC name header and the apps
        grid; appFragmentContainer is layout_below this row so the grid
        flows naturally beneath when shown.
    -->
    <LinearLayout
        android:id="@+id/steamProfileBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/appListText"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingLeft="24dp"
        android:paddingRight="24dp"
        android:paddingTop="4dp"
        android:paddingBottom="8dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/steamProfileLabel"
            android:tag="vs_meta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/steam_account_label"
            android:textColor="@color/vs_lime"
            android:textSize="11sp"
            android:fontFamily="@font/ibm_plex_mono"
            android:letterSpacing="0.18"
            android:paddingRight="12dp" />

        <Spinner
            android:id="@+id/steamProfileSpinner"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:minHeight="44dp" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/appFragmentContainer"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:layout_alignParentLeft="true"
        android:layout_alignParentStart="true"
        android:layout_alignParentRight="true"
        android:layout_alignParentEnd="true"
        android:layout_alignParentBottom="true"
        android:layout_below="@+id/steamProfileBar" />

</RelativeLayout>

<?xml version="1.0" encoding="utf-8"?>
<!--
    VipleStream editorial game tile.
    Keeps grid_image / grid_overlay / grid_text IDs for the adapter
    binding; wraps them in an ink2 frame with a "§ LIBRARY" meta label
    above and a paper-bold title below the box art.
-->
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="150dp"
    android:layout_height="240dp"
    android:padding="6dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@drawable/vs_tile_bg"
        android:padding="8dp">

        <TextView
            android:tag="vs_meta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:text="§ LIBRARY"
            android:textSize="9sp"
            android:textColor="@color/vs_mute"
            android:fontFamily="@font/ibm_plex_mono"
            android:letterSpacing="0.14" />

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@color/vs_ink">

            <ImageView
                android:id="@+id/grid_image"
                android:scaleType="centerCrop"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <ImageView
                android:id="@+id/grid_overlay"
                android:layout_centerInParent="true"
                android:layout_width="48dp"
                android:layout_height="48dp" />
        </RelativeLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="8dp"
            android:background="@color/vs_line" />

        <TextView
            android:id="@+id/grid_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/vs_paper"
            android:textSize="13sp"
            android:textStyle="bold"
            android:fontFamily="@font/inter"
            android:gravity="left"
            android:maxLines="2"
            android:ellipsize="end" />
    </LinearLayout>
</RelativeLayout>

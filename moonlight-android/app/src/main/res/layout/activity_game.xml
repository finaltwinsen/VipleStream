<merge xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Game" >

    <View
        android:id="@+id/backgroundTouchView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="center" />

    <com.limelight.ui.StreamView
        android:id="@+id/surfaceView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="center"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:focusedByDefault="true"
        android:defaultFocusHighlightEnabled="false">
        <requestFocus />
    </com.limelight.ui.StreamView>

    <TextView
        android:id="@+id/performanceOverlay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="8dp"
        android:layout_marginStart="8dp"
        android:layout_marginTop="8dp"
        android:layout_gravity="left"
        android:textSize="10sp"
        android:fontFamily="monospace"
        android:textColor="#FFD4FF3A"
        android:gravity="left"
        android:background="#B0141710"
        android:padding="6dp"
        android:lineSpacingMultiplier="1.05"
        android:preferKeepClear="true"
        android:visibility="gone" />

    <TextView
        android:id="@+id/notificationOverlay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginRight="10dp"
        android:layout_marginEnd="10dp"
        android:layout_marginTop="10dp"
        android:layout_gravity="right"
        android:textAppearance="?android:attr/textAppearanceLarge"
        android:gravity="right"
        android:background="#80000000"
        android:preferKeepClear="true"
        android:visibility="gone" />

    <!-- VipleStream §N.5 — File transfer progress overlay (left-bottom).
         獨立 view 不跟 connection status notificationOverlay (right-top) 衝突.
         Stream 中收/送 file 進行時持續顯示 0-100% + 檔名，完成或失敗 3 秒後
         自動 fade-out 避免長期擋畫面. -->
    <TextView
        android:id="@+id/fileTransferOverlay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="10dp"
        android:layout_marginStart="10dp"
        android:layout_marginBottom="10dp"
        android:layout_gravity="left|bottom"
        android:textAppearance="?android:attr/textAppearanceMedium"
        android:textColor="#FFD4FF3A"
        android:gravity="left"
        android:background="#B0141710"
        android:padding="8dp"
        android:preferKeepClear="true"
        android:visibility="gone" />

</merge>

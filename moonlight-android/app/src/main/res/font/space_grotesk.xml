<?xml version="1.0" encoding="utf-8"?>
<!--
    VipleStream · Space Grotesk font-family resource.
    The bundled space_grotesk_var.ttf is a single VARIABLE font
    carrying the whole wght axis.  Android's fontFamily="@font/…"
    resolver can't pick a weight out of a variable font on its own,
    which is why the straight android:fontFamily="@font/space_grotesk"
    previously fell through to the system default.
    Declaring weights explicitly here with android:fontVariationSettings
    lets the framework instance the right glyphs from the variable
    TTF at rendering time.  Requires Android API 26+; the app's
    minSdk is 21 but on older devices variable-font weight selection
    isn't supported anyway, so they'll just get the variable font's
    default instance (~400 regular) which is acceptable.
-->
<font-family xmlns:android="http://schemas.android.com/apk/res/android">
    <font
        android:fontStyle="normal"
        android:fontWeight="400"
        android:font="@font/space_grotesk_var"
        android:fontVariationSettings="'wght' 400" />
    <font
        android:fontStyle="normal"
        android:fontWeight="500"
        android:font="@font/space_grotesk_var"
        android:fontVariationSettings="'wght' 500" />
    <font
        android:fontStyle="normal"
        android:fontWeight="600"
        android:font="@font/space_grotesk_var"
        android:fontVariationSettings="'wght' 600" />
    <font
        android:fontStyle="normal"
        android:fontWeight="700"
        android:font="@font/space_grotesk_var"
        android:fontVariationSettings="'wght' 700" />
</font-family>

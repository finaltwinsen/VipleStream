<?xml version="1.0" encoding="utf-8"?>
<!--
    VipleStream H.5 capability badge background.
    Lime-bordered ink3 chip; mirrors the Qt client's PcView badge so
    same-vendor peers look the same on both platforms.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/vs_ink3" />
    <stroke android:width="1dp" android:color="@color/vs_lime" />
    <corners android:radius="0dp" />
</shape>

<?xml version="1.0" encoding="utf-8"?>
<!--
    VipleStream editorial tile background.
    Warm-ink raised surface with a hairline frame — used as the
    background drawable for pc_grid_item and app_grid_item so every
    tile on the home / library screens reads as a bordered magazine
    card instead of blending into the dark ink window background.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/vs_ink2" />
    <stroke android:width="1dp" android:color="@color/vs_line2" />
    <corners android:radius="0dp" />
</shape>

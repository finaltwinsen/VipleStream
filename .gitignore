# ── Build outputs ──
Sunshine/build/
Sunshine/build_mingw/
moonlight-qt/**/release/
moonlight-qt/**/debug/
moonlight-qt/**/Makefile
moonlight-qt/**/Makefile.*
moonlight-qt/config.log
moonlight-qt/.qmake.stash

# ── Temp / Release / Deploy ──
temp/
release/
sunshine-deploy/
moonlight-deploy/
sunshine-backup/
temp_*.cmd

# ── Android build outputs ──
moonlight-android/app/build/
moonlight-android/.gradle/
moonlight-android/build/

# ── Benchmark / test output files ──
scripts/benchmark/*.json
scripts/benchmark/*.csv
scripts/benchmark/*.txt

# ── External dependencies (auto-downloaded by build) ──
vcpkg/
Sunshine/node_modules/

# ── Large binary blobs not needed for Windows build ──
Sunshine/third-party/build-deps/third-party/FFmpeg/FFmpeg/
Sunshine/third-party/build-deps/third-party/FFmpeg/SVT-AV1/
Sunshine/third-party/build-deps/third-party/FFmpeg/Vulkan-Loader/
Sunshine/third-party/build-deps/third-party/FFmpeg/x264/
Sunshine/third-party/build-deps/third-party/FFmpeg/x265_git/
Sunshine/third-party/build-deps/third-party/FFmpeg/AMF/Thirdparty/ffmpeg/
moonlight-qt/libs/windows/lib/arm64/
moonlight-qt/libs/mac/

# ── Debug symbols ──
*.pdb

# ── Packages / archives ──
*.zip

# ── Logs ──
*.log

# ── Compiled objects / binaries ──
*.obj
*.exe
*.ilk
*.exp

# ── FRUC test build artifacts ──
tools/fruc_test/*.exe
tools/fruc_test/*.obj
tools/fruc_test/*.dll
tools/fruc_test/output.txt
tools/fruc_test/build_out.txt

# ── Local config (machine-specific paths) ──
build-config.local.cmd

# ── IDE / tool configs ──
.vscode/
.claude/

# ── OS files ──
Thumbs.db
Desktop.ini
.DS_Store
